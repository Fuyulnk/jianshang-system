{
  "name": "jianshang-backend",
  "version": "1.0.0",
  "description": "简尚系统后端 - Node.js + Fastify",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "db:check": "node scripts/db-maintenance-check.mjs",
    "db:checkpoint": "node scripts/db-maintenance-check.mjs --checkpoint",
    "db:vacuum": "node scripts/db-maintenance-check.mjs --checkpoint --vacuum",
    "seed:safe-ai": "node scripts/seed-safe-ai-test-db.mjs",
    "smoke:rbac": "node scripts/rbac-smoke.mjs",
    "smoke:ai-mock": "node scripts/ai-mock-smoke.mjs",
    "smoke:ai-real": "AI_REAL_EGRESS_ENABLED=1 AI_TEST_DATASET=1 node scripts/ai-real-deepseek-smoke.mjs"
  },
  "keywords": [
    "jianshang",
    "backend",
    "fastify"
  ],
  "author": "lnk",
  "license": "MIT",
  "dependencies": {
    "@fastify/compress": "^5.0.0",
    "@fastify/static": "^7.0.4",
    "bcrypt": "^5.1.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^16.3.0",
    "fastify": "^4.24.0",
    "jsonwebtoken": "^9.0.3",
    "socket.io": "^4.7.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.0"
  }
}
